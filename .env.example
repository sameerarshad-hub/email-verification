# =====================================================================
# MailForge environment variables
# Copy this file to `.env` and adjust as needed.
#   cp .env.example .env
# =====================================================================

# SQLite database location (must be a `file:` URL).
# - Docker path: leave as-is (matches the volume mount in docker-compose.yml).
# - Non-Docker path: point at a persistent location, e.g.
#       DATABASE_URL=file:/var/lib/mailforge/custom.db
DATABASE_URL=file:/app/data/custom.db

# HTTP server
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production
